---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ArrowRight, Calendar } from "lucide-react";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title="arndev - blog"
  description="My personal blog where I share my thoughts and experiences about tech related stuff."
>
  <!-- Bio Header -->
  <header class="flex flex-col gap-6 items-start pt-20 lg:pt-0">
    <div class="relative">
      <div
        class="size-20 rounded-full bg-surface shadow-soft border-4 border-white overflow-hidden z-10 relative"
      >
        <img
          src="/blog-avatar-profile.png"
          alt="Arndev"
          class="w-full h-full object-cover transform scale-[1.5] object-[center_10px]"
        />
      </div>
      <div
        class="absolute inset-0 rounded-full border border-primary/20 scale-110 pointer-events-none"
      >
      </div>
    </div>
    <div class="max-w-2xl">
      <h2
        class="text-[32px] font-bold text-text-main font-display leading-tight tracking-[-0.02em] mb-3"
      >
        Hi, I'm Arndev
      </h2>
      <p class="text-[18px] text-text-muted leading-[1.6] font-medium">
        This is my personal blog where I share my thoughts and experiences about
        tech related stuff.
      </p>
    </div>
  </header>

  <!-- Latest Updates Feed -->
  <section class="flex flex-col gap-6">
    <div class="flex items-center justify-between mb-2">
      <h3 class="text-[20px] font-bold text-text-main font-display">
        Latest Updates
      </h3>
      <a
        href="/blog"
        class="text-sm font-bold text-primary hover:text-primary/80 transition-colors flex items-center gap-1"
      >
        View all <ArrowRight className="w-4 h-4" />
      </a>
    </div>

    {
      latestPosts.map((post) => (
        <a href={`/blog/${post.id}`}>
          <article class="bg-surface rounded-card p-6 shadow-soft card-hover border border-border-soft/30 cursor-pointer group">
            <div class="flex flex-col md:flex-row gap-6">
              <div class="flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-3">
                  <span
                    class={`px-3 py-1 ${post.data.categoryBg || "bg-blue-50 text-blue-800"} text-[12px] font-bold uppercase tracking-wider rounded-full`}
                  >
                    {post.data.category}
                  </span>
                  <span class="text-text-muted text-sm font-medium flex items-center gap-1">
                    <Calendar className="w-4 h-4" />
                    {formatDate(post.data.date)}
                  </span>
                </div>
                <h4 class="text-[22px] font-bold text-text-main mb-2 font-display leading-tight">
                  {post.data.title}
                </h4>
                <p class="text-text-muted text-[15px] leading-[1.6] mb-5">
                  {post.data.excerpt}
                </p>
                <div class="flex flex-wrap gap-2 mt-auto">
                  {post.data.tags?.map((tag) => (
                    <span class="px-3 py-1.5 bg-sidebar text-text-muted text-xs font-semibold rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        </a>
      ))
    }
  </section>
</BaseLayout>
