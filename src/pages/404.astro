---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ArrowLeft, Home } from "lucide-react";
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center gap-8">
    <div class="text-[120px] font-bold text-primary/10 font-display leading-none">
      404
    </div>
    <div class="flex flex-col gap-4">
      <h1 class="text-3xl font-bold text-text-main">Page not found</h1>
      <p class="text-text-muted text-lg max-w-md">
        The page you're looking for doesn't exist or has been moved.
      </p>
    </div>
    <div class="flex gap-4">
      <a
        href="/"
        class="flex items-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-full hover:bg-primary/90 transition-colors"
      >
        <Home className="w-5 h-5" />
        Go Home
      </a>
      <a
        href="/blog"
        class="flex items-center gap-2 px-6 py-3 bg-surface border border-border-soft text-text-main font-bold rounded-full hover:bg-sidebar transition-colors"
      >
        <ArrowLeft className="w-5 h-5" />
        Back to Blog
      </a>
    </div>
  </div>
</BaseLayout>
