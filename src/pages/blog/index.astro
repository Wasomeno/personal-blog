---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { BookOpen, Calendar, ArrowRight } from "lucide-react";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Blog" description="All blog posts">
  <!-- Category Header -->
  <header class="flex flex-col gap-4 pt-10">
    <h1
      class="text-4xl md:text-[40px] font-extrabold leading-tight tracking-[-0.033em] text-text-main"
    >
      Blog
    </h1>
    <p class="text-text-muted text-lg font-medium max-w-2xl leading-relaxed">
      All of the blog posts that i've written.
    </p>
  </header>

  <!-- Content Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {
      sortedPosts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.mdx?$/, "")}`}>
          <article class="bg-surface rounded-2xl shadow-soft card-hover overflow-hidden flex flex-col group cursor-pointer border border-black/5">
            <div class="p-6 flex flex-col gap-3">
              <h2 class="text-xl font-bold leading-tight text-text-main">
                {post.data.title}
              </h2>
              <p class="text-text-muted text-sm leading-relaxed line-clamp-2">
                {post.data.excerpt}
              </p>
              <div class="mt-4 flex items-center gap-2 text-xs font-semibold text-text-muted">
                <Calendar className="w-4 h-4" />
                <span>
                  {post.data.date.toLocaleDateString("en-US", {
                    month: "long",
                    day: "numeric",
                    year: "numeric",
                  })}
                </span>
                <span class="w-1 h-1 rounded-full bg-blue-300" />
                <span>{post.data.readTime}</span>
              </div>
            </div>
          </article>
        </a>
      ))
    }
  </div>
</BaseLayout>
