---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ArrowLeft, Calendar, ArrowRight, Share2 } from "lucide-react";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const postId = post.id.replace(/\.mdx?$/, "");
const currentIndex = sortedPosts.findIndex(
  (p) => p.id.replace(/\.mdx?$/, "") === postId,
);
const nextPost =
  currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

const postUrl = new URL(`/blog/${postId}`, Astro.site);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  url: postUrl,
  author: {
    "@type": "Person",
    name: "Arndev",
    url: Astro.site,
  },
  publisher: {
    "@type": "Person",
    name: "Arndev",
  },
};
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <meta property="og:type" content="article" />
    <meta
      property="article:published_time"
      content={post.data.date.toISOString()}
    />
  </Fragment>
  <article class="w-full max-w-[680px] lg:max-w-[800px] pb-32 pt-10 lg:pt-0">
    <!-- Back Button -->
    <a
      href="/blog"
      class="inline-flex h-10 px-5 items-center justify-center rounded-full bg-surface text-text-main text-[14px] font-bold tracking-[0.02em] shadow-soft border border-border-soft hover:shadow-hover hover:-translate-x-1 transition-all duration-200 mb-6"
    >
      <ArrowLeft className="w-[18px] h-[18px] mr-2" />
      <span>Back</span>
    </a>

    <!-- Article Header -->
    <header class="mb-12">
      <div class="flex items-center gap-2 mb-6">
        <span
          class={`${post.data.categoryBg ?? "bg-blue-50 text-blue-800"} text-xs font-bold uppercase tracking-wider rounded-full px-3 py-1`}
        >
          {post.data.category}
        </span>
      </div>
      <h1
        class="text-text-main text-[40px] md:text-[48px] font-bold leading-[1.1] tracking-[-0.02em] mb-6"
      >
        {post.data.title}
      </h1>
      <div
        class="flex items-center gap-3 text-text-muted text-[15px] font-medium"
      >
        <Calendar className="w-4 h-4" />
        <time datetime={post.data.date.toISOString().split("T")[0]}>
          {
            post.data.date.toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })
          }
        </time>
        <span class="w-1 h-1 rounded-full bg-[#D1D1D0]"></span>
        <span>{post.data.readTime}</span>
      </div>
    </header>

    <!-- Article Body -->
    <div class="prose-body text-text-main text-lg leading-[1.8]">
      <Content />
    </div>

    <!-- Tags -->
    {
      post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 pt-8 border-t border-border-soft">
          {post.data.tags.map((tag: string) => (
            <span class="px-4 py-2 bg-sidebar text-text-muted text-sm font-semibold rounded-full">
              #{tag}
            </span>
          ))}
        </div>
      )
    }

    <!-- End of Article Actions -->
    <div
      class="mt-16 pt-8 border-t border-border-soft flex items-center justify-between"
    >
      <div class="flex items-center gap-4">
        <span class="text-text-muted font-medium text-sm">Share:</span>
        <button
          class="w-10 h-10 rounded-full bg-surface border border-border-soft flex items-center justify-center text-text-muted hover:text-primary hover:border-primary transition-colors"
        >
          <Share2 className="w-4 h-4" />
        </button>
      </div>
      <a
        href="/blog"
        class="flex items-center gap-2 text-primary font-bold text-sm hover:opacity-80 transition-opacity"
      >
        All Posts
        <ArrowRight className="w-[18px] h-[18px]" />
      </a>
    </div>

    <!-- Up Next Section -->
    {
      nextPost && (
        <div class="mt-16 pt-12 border-t border-border-soft">
          <h3 class="text-[14px] font-bold uppercase tracking-widest text-text-muted mb-6">
            Up Next
          </h3>
          <a
            href={`/blog/${nextPost.id.replace(/\.mdx?$/, "")}`}
            class="group bg-surface rounded-card p-6 shadow-soft hover:shadow-hover hover:bg-stone-100 transition-all duration-300 flex gap-6 items-start border border-border-soft/30"
          >
            <div class="flex-1">
              <h4 class="font-bold text-xl text-text-main mb-2">
                {nextPost.data.title}
              </h4>
              <p class="text-text-muted text-sm line-clamp-2">
                {nextPost.data.excerpt}
              </p>
            </div>
          </a>
        </div>
      )
    }
  </article>
</BaseLayout>

<style>
  .prose-body :global(h2) {
    @apply text-[28px] font-bold tracking-[-0.02em] text-text-main mt-12 mb-6 leading-tight;
  }
  .prose-body :global(p) {
    @apply mb-8;
  }
  .prose-body :global(ul),
  .prose-body :global(ol) {
    @apply mb-8 pl-6;
  }
  .prose-body :global(li) {
    @apply text-text-muted mb-2;
  }
  .prose-body :global(pre) {
    @apply bg-text-main rounded-card p-6 mb-8 overflow-x-auto;
  }
  .prose-body :global(code) {
    @apply font-mono text-[14px] leading-relaxed text-surface;
  }
  .prose-body :global(blockquote) {
    @apply my-10 p-6 bg-sidebar rounded-card border-l-4 border-primary;
  }
  .prose-body :global(strong) {
    @apply font-bold text-text-main;
  }
  .prose-body :global(a) {
    @apply text-primary underline hover:opacity-80;
  }
</style>
