---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { FolderKanban, ArrowRight, ExternalLink } from 'lucide-react';

const projects = [
  {
    name: 'cmdtest',
    description: 'CLI testing for Zig. A simple and ergonomic testing framework for command-line interfaces.',
    href: '/docs/cmdtest',
    tags: ['Zig', 'Testing'],
    date: 'Jan 2024',
    readTime: '5 min read',
  },
  {
    name: 'xdgdir',
    description: "A tiny Rust crate that finds the right directories for your app's config and data, following the XDG spec.",
    href: '/docs/xdgdir',
    tags: ['Rust', 'Library'],
    date: 'Nov 2023',
    readTime: '3 min read',
  },
  {
    name: 'envfmt',
    description: 'A tiny Rust crate to expand environment variables in a string, just like your shell does.',
    href: '/docs/envfmt',
    tags: ['Rust', 'Library'],
    date: 'Oct 2023',
    readTime: '4 min read',
  },
];
---

<BaseLayout title="Projects" description="Open-source tools and libraries">
  <!-- Category Header -->
  <header class="flex flex-col gap-4">
    <div class="flex items-center gap-3 text-primary text-sm font-bold uppercase tracking-wider mb-2">
      <FolderKanban className="w-[18px] h-[18px]" />
      Category
    </div>
    <h1 class="text-4xl md:text-[40px] font-extrabold leading-tight tracking-[-0.033em] text-text-main">Projects</h1>
    <p class="text-text-muted text-lg font-medium max-w-2xl leading-relaxed">
      A collection of my open-source tools and libraries. Each one started as an experiment to learn something new or to fix a problem I had. They're mostly written in Rust, simply because I enjoy building things with it.
    </p>
  </header>

  <!-- Content Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((project) => (
      <article class="bg-surface rounded-2xl shadow-soft card-hover overflow-hidden flex flex-col group cursor-pointer border border-black/5">
        <div class="h-[160px] w-full bg-gradient-to-br from-blue-200/20 to-blue-300/20 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-200/30 to-blue-300/30 group-hover:scale-105 transition-transform duration-500"></div>
        </div>
        <div class="p-6 flex flex-col gap-3 flex-1">
          <h2 class="text-xl font-bold leading-tight text-text-main flex items-center gap-2">
            {project.name}
            <ExternalLink className="w-4 h-4" />
          </h2>
          <p class="text-text-muted text-sm leading-relaxed line-clamp-2">{project.description}</p>
          <div class="flex flex-wrap gap-2 mt-auto pt-2">
            {project.tags.map((tag) => (
              <span class="px-3 py-1.5 bg-sidebar text-text-muted text-xs font-semibold rounded-full">{tag}</span>
            ))}
          </div>
          <div class="mt-4 flex items-center gap-2 text-xs font-semibold text-text-muted">
            <span>{project.date}</span>
            <span class="w-1 h-1 rounded-full bg-blue-300"></span>
            <span>{project.readTime}</span>
          </div>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
