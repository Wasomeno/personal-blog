---
import { Home, BookOpen, FolderKanban, ChefHat, Shield, Radio, Github, Twitter, Rss, Map } from 'lucide-react';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A personal blog' } = Astro.props;

const navigation = [
  { name: 'Home', href: '/', icon: Home },
  { name: 'Blog', href: '/blog', icon: BookOpen },
  { name: 'Projects', href: '/projects', icon: FolderKanban },
];

const cookbooks = [
  { name: 'Foundry', href: '/cookbooks/foundry' },
  { name: 'TypeScript', href: '/cookbooks/typescript' },
  { name: 'Rust', href: '/cookbooks/rust' },
  { name: 'VS Code', href: '/cookbooks/vscode' },
  { name: 'Zig', href: '/cookbooks/zig' },
];

const audits = [
  { name: 'Cantina', href: 'https://cantina.xyz/u/sepyke' },
  { name: 'Sherlock', href: 'https://audits.sherlock.xyz/watson/pyk' },
];

const elsewhere = [
  { name: 'GitHub', href: 'https://github.com/pyk', icon: Github },
  { name: 'Twitter', href: 'https://x.com/sepyke', icon: Twitter },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=JetBrains+Mono:wght@100..800&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans antialiased bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100">
    <header class="border-b border-gray-200 dark:border-gray-800">
      <nav class="max-w-5xl mx-auto px-4 py-4">
        <ul class="flex items-center gap-6">
          {navigation.map((item) => (
            <li>
              <a href={item.href} class="flex items-center gap-2 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                <item.icon class="w-4 h-4" />
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <div class="flex">
      <!-- Sidebar -->
      <aside class="hidden lg:block w-64 border-r border-gray-200 dark:border-gray-800 min-h-screen p-4">
        <h3 class="font-semibold mb-4">Notebook</h3>
        
        <nav class="space-y-6">
          <div>
            <h4 class="text-sm text-gray-500 dark:text-gray-400 mb-2 uppercase tracking-wide">Cookbooks</h4>
            <ul class="space-y-1">
              {cookbooks.map((item) => (
                <li>
                  <a href={item.href} class="block hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h4 class="text-sm text-gray-500 dark:text-gray-400 mb-2 uppercase tracking-wide">Audits</h4>
            <ul class="space-y-1">
              {audits.map((item) => (
                <li>
                  <a href={item.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                    {item.name}
                    <span class="text-xs text-gray-400">↗</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h4 class="text-sm text-gray-500 dark:text-gray-400 mb-2 uppercase tracking-wide">Elsewhere</h4>
            <ul class="space-y-1">
              {elsewhere.map((item) => (
                <li>
                  <a href={item.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                    <item.icon class="w-4 h-4" />
                    {item.name}
                  </a>
                </li>
              ))}
              <li>
                <a href="/rss.xml" class="flex items-center gap-2 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                  <Rss class="w-4 h-4" />
                  RSS
                </a>
              </li>
              <li>
                <a href="/sitemap-index.xml" class="flex items-center gap-2 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                  <Map class="w-4 h-4" />
                  Sitemap
                </a>
              </li>
            </ul>
          </div>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 max-w-3xl mx-auto p-6">
        <slot />
      </main>
    </div>

    <footer class="border-t border-gray-200 dark:border-gray-800 mt-12">
      <div class="max-w-5xl mx-auto px-4 py-6 flex justify-between items-center">
        <p class="text-gray-500 dark:text-gray-400">&copy; 2026 persona-blog</p>
        <div class="flex gap-4">
          <a href="/sitemap-index.xml" class="text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
            <Map class="w-5 h-5" />
          </a>
          <a href="/rss.xml" class="text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
            <Rss class="w-5 h-5" />
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
