---
import { Home, Mail, Menu, Search } from "lucide-react";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A personal blog" } = Astro.props;

const navItems = [{ name: "Home", href: "/", icon: Home }];
---

<!doctype html>
<html lang="en" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.png" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body
    class="bg-background-light text-text-main font-sans antialiased flex min-h-screen"
  >
    <!-- Mobile Header -->
    <header
      class="lg:hidden fixed top-0 w-full z-50 bg-background-light border-b border-border-soft shadow-soft"
    >
      <div class="flex justify-between items-center px-6 py-4">
        <button
          class="flex items-center gap-3 hover:opacity-80 transition-opacity active:scale-95 duration-200"
        >
          <Menu className="w-6 h-6 text-primary" />
        </button>
        <h1 class="font-display font-bold tracking-tight text-xl text-primary">
          Arndev
        </h1>
        <button
          class="hover:opacity-80 transition-opacity active:scale-95 duration-200"
        >
          <Search className="w-6 h-6 text-primary" />
        </button>
      </div>
    </header>

    <!-- Desktop Sidebar -->
    <aside
      class="hidden lg:flex flex-col py-8 w-[280px] bg-sidebar h-screen sticky top-0 border-r border-border-soft/50 z-10 shrink-0"
    >
      <!-- Navigation -->
      <nav class="flex-1 px-4 overflow-y-auto pb-6 space-y-6">
        <!-- Content Section -->
        <div>
          <div
            class="flex items-center justify-between px-2 py-1.5 text-xs font-bold text-text-muted uppercase tracking-wider mb-1"
          >
            <span>Content</span>
          </div>
          <div class="flex flex-col gap-1">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class="flex items-center gap-3 px-3 h-[36px] rounded-lg text-text-muted hover:bg-white/50 transition-colors"
                >
                  <item.icon className="w-5 h-5" />
                  <span class="text-sm font-medium">{item.name}</span>
                </a>
              ))
            }
          </div>
        </div>
      </nav>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 flex justify-center py-16 px-8 overflow-x-hidden">
      <div class="w-full max-w-[800px] flex flex-col gap-12">
        <slot />
      </div>
    </main>

    <!-- Mobile Bottom Navigation -->
    <nav
      class="lg:hidden fixed bottom-0 left-0 w-full h-20 bg-white/80 backdrop-blur-md rounded-t-[32px] z-50 border-t border-border-soft shadow-[-12px_0_40px_rgba(45,43,42,0.04)]"
    >
      <div class="flex justify-around items-center h-full px-4">
        {
          navItems.map((item, index) => (
            <a
              href={item.href}
              class={`flex flex-col items-center justify-center transition-colors active:scale-90 duration-150 ${
                index === 0 ? "text-primary scale-110" : "text-text-muted"
              }`}
            >
              <item.icon className="w-6 h-6" />
              <span class="font-bold text-[11px] uppercase tracking-[0.1em] mt-1">
                {item.name}
              </span>
            </a>
          ))
        }
      </div>
    </nav>
  </body>
</html>
